# SwiftyPOS Environment Variables
# ================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# For Vercel deployment, set these in:
#   Vercel Dashboard → Project → Settings → Environment Variables
#
# VITE_* variables are embedded in the client bundle at build time.
# They are PUBLIC by design — the Supabase anon key is safe to expose.
# Row-Level Security (RLS) in PostgreSQL is the true access control boundary.

VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
